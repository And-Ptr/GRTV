from playwright.sync_api import sync_playwright
import time

def get_alpha_stream():
    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)
        page = browser.new_page()

        page.goto("https://www.alphacyprus.com.cy/live", wait_until="networkidle")

        found_url = None

        def handle_request(request):
            nonlocal found_url
            url = request.url
            if ".m3u8" in url:
                found_url = url

        page.on("request", handle_request)

        # Wait up to 30 seconds for the stream to appear
        for _ in range(30):
            if found_url:
                break
            time.sleep(1)

        browser.close()
        return found_url

if __name__ == "__main__":
    url = get_alpha_stream()
    if url:
        print(url)
    else:
        print("# ERROR: No m3u8 found")

