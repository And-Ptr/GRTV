from playwright.sync_api import sync_playwright
import time

def get_alpha_stream():
    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True, args=["--autoplay-policy=no-user-gesture-required"])
        page = browser.new_page()

        print("Loading Alpha Cyprus...")
        page.goto("https://www.alphacyprus.com.cy/live", wait_until="networkidle")

        found_url = None

        def handle_request(request):
            nonlocal found_url
            url = request.url
            if ".m3u8" in url:
                found_url = url

        page.on("request", handle_request)

        # Try to click the play button
        try:
            page.click("button.vjs-big-play-button", timeout=5000)
            print("Clicked play button")
        except:
            print("Play button not found, maybe autoplay works")

        # Wait up to 60 seconds for the stream
        for _ in range(60):
            if found_url:
                break
            time.sleep(1)

        browser.close()
        return found_url

if __name__ == "__main__":
    url = get_alpha_stream()
    if url:
        print(url)
    else:
        print("# ERROR: No m3u8 found")


